{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "startCommand": "uvicorn src.api:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/health",
    "restartPolicy": {
      "type": "ON_FAILURE"
    }
  }
}
